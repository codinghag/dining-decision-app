# Copy this file to `.env` and fill in the values from your Supabase project.
# Anything prefixed with EXPO_PUBLIC_ is embedded in the client bundle, so it
# must be safe to expose publicly.

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Supabase "anon" public API key (safe for the client — RLS enforces access).
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# NOTE: The Google Places API key is NOT set here and must NEVER be an
# EXPO_PUBLIC_* variable (that would ship it in the client bundle, visible in
# the web network tab). It is a server-side Supabase Edge Function secret only:
#
#   supabase secrets set GOOGLE_PLACES_API_KEY=your_key_here
#
# The app calls the places-search / places-details / places-resolve-link edge
# functions, which hold the key and proxy to Google.
# -----------------------------------------------------------------------------
